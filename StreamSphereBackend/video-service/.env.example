# Runtime
PORT=8083
SERVER_PORT=8083

# ImageKit
IMAGE_URL=https://ik.imagekit.io/replace
IMAGE_PRIVATE_KEY=private_replace
IMAGE_PUBLIC_KEY=public_replace

# Service-to-service
CENTRAL_API_URL=http://localhost:8084/api/v1/central

# Upload limits
MAX_UPLOAD_FILE_SIZE=500MB
MAX_UPLOAD_REQUEST_SIZE=500MB

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Swagger / Docs
SWAGGER_UI_PATH=/swagger-ui.html
API_DOCS_PATH=/v3/api-docs
APP_DOCS_EXTERNAL_URL=https://docs.streamsphere.com/video

# Actuator
MANAGEMENT_ENDPOINTS_EXPOSE=health,info
