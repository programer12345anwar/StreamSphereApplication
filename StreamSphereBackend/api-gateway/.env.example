# Runtime
PORT=8080
SERVER_PORT=8080

# Upstream service URLs
CENTRAL_SERVICE_URL=http://localhost:8084
VIDEO_SERVICE_URL=http://localhost:8083
NOTIFICATION_SERVICE_URL=http://localhost:8082

# CORS
# Allow common dev hosts/ports (vite / other dev servers)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Gateway tuning
GATEWAY_CONNECT_TIMEOUT_MS=10000
GATEWAY_RESPONSE_TIMEOUT=30s
GATEWAY_LOG_LEVEL=INFO

# Swagger / Docs
SWAGGER_UI_PATH=/swagger-ui.html
API_DOCS_PATH=/v3/api-docs

# Actuator
MANAGEMENT_ENDPOINTS_EXPOSE=health,info,gateway
